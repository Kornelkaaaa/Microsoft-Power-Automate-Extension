{
  "manifest_version": 3,
  "name": "Flow Finder — Power Automate connector catalog",
  "version": "1.2.0",
  "description": "Searchable catalog of Power Automate / Power Platform connectors, actions, and triggers. Find the block that solves your use case.",
  "minimum_chrome_version": "114",
  "permissions": ["sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Flow Finder",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
